{
  "name": "unrpyc-pure",
  "version": "1.1.0",
  "description": "Pure JS Ren'Py .rpyc decompiler with npm CLI and JS API",
  "type": "module",
  "files": [
    "src/**/*.js",
    "README.md",
    "docs/**/*.md"
  ],
  "bin": {
    "unrpyc": "src/node/cli.js"
  },
  "exports": {
    ".": {
      "browser": "./src/browser.js",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./cli": "./src/node/cli.js",
    "./browser": "./src/browser.js"
  },
  "scripts": {
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asakuraminani/unrpyc-pure.git"
  },
  "keywords": [
    "renpy",
    "rpyc",
    "decompiler",
    "unrpyc"
  ],
  "author": "あさくらみなみ",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/asakuraminani/unrpyc-pure/issues"
  },
  "homepage": "https://github.com/asakuraminani/unrpyc-pure",
  "dependencies": {
    "pickleparser": "^0.2.1",
    "fflate": "^0.8.2"
  }
}
